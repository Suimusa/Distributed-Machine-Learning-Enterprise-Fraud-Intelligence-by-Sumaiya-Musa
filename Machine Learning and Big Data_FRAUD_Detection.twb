      <aliases enabled='yes' />
      <column caption='Fraud Rate' datatype='real' name='[Calculation_0981353665273858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [is_fraud] = TRUE THEN 1 ELSE 0 END) / COUNT([transaction_id])' />
      </column>
      <column caption='High Risk Flag' datatype='string' name='[Calculation_0981353665482755]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [persona_fraud_risk] &gt; [merchant_fraud_rate] THEN &apos;High Risk&apos; ELSE &apos;Low Risk&apos; END' />
      </column>
      <column caption='Fraud Rate per Merchant (LOD)' datatype='real' name='[Calculation_0981353666433028]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [merchant_category] : SUM(IF [is_fraud]=TRUE THEN 1 ELSE 0 END) / COUNT([transaction_id]) }' />
      </column>
      <column caption='Night Fraud Rate' datatype='real' name='[Calculation_0981353666637829]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [is_night_txn]=1 AND [is_fraud]=TRUE THEN 1 ELSE 0 END) / SUM(IF [is_night_txn]=1 THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Processing Time' datatype='real' name='[Calculation_0981353889488902]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='[time_since_last]-[time_since_last_transaction]' />
      </column>
      <column caption='Volume' datatype='integer' name='[Calculation_0981353890947079]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='sum([user_txn_count_total])' />
      </column>
      <column caption='Cost per 1M Transactions' datatype='real' name='[Calculation_0981353893158920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[amount_ngn]/[time_since_last_transaction]' />
      </column>
